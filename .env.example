# Web
WEB_PORT=8787

# API paging/limits (used by frontend calculations)
API_ACADEMIC_YEAR_ID=13
API_SCHOOL_ID=0
# Optional override for analytics source (class teacher mode, comma-separated)
API_CLASS_UNIT_IDS=
API_GROUPS_PER_PAGE=300
API_MARKS_PER_PAGE=300
API_ATTENDANCES_PER_PAGE=1000
API_INCLUDE_ATTENDANCES=true

# Default headers for API proxy (can be overridden from UI)
API_ROLE_ID=9
API_HOST_ID=9
API_AID=13
API_SUBSYSTEM=journalsw

# Academic range for analytics requests
EXPORT_START_AT=2025-09-01
EXPORT_STOP_AT=2026-08-31

# Trimester boundaries
TRIMESTER_1_LABEL=1 триместр
TRIMESTER_1_START=2025-09-01
TRIMESTER_1_END=2025-11-30
TRIMESTER_2_LABEL=2 триместр
TRIMESTER_2_START=2025-12-01
TRIMESTER_2_END=2026-02-28
TRIMESTER_3_LABEL=3 триместр
TRIMESTER_3_START=2026-03-01
TRIMESTER_3_END=2026-05-23
